# OpenAI API 配置
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 如果你用国内兼容 OpenAI 接口的模型（如 DeepSeek、通义千问等），
# 只需修改 OPENAI_BASE_URL 和 OPENAI_API_KEY 即可，无需改代码。
# 例如 DeepSeek:
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-deepseek-key

# 模型名称
MODEL_NAME=deepseek-v4-flash



# JWT 认证配置
# 生产环境请换成随机长字符串（至少 32 位）
JWT_SECRET_KEY=papermind-change-this-secret-in-production
JWT_EXPIRE_HOURS=168
