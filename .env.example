# ===== LLM API 配置（OpenAI 兼容接口） =====
# 支持 DeepSeek / GPT-4o / 通义千问 / Ollama 等
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:   https://api.openai.com/v1
# 通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama:   http://localhost:11434/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=deepseek-v4-flash

# ===== Embedding API 配置（可与 LLM 使用不同 provider） =====
# 不填则默认使用 OPENAI_API_KEY 和 OPENAI_BASE_URL
# EMBEDDING_API_KEY=sk-your-embedding-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large

# ===== Neo4j 图数据库配置（可选，不配置则知识图谱功能自动降级） =====
# 本地开发: bolt://localhost:7687
# Docker 部署: bolt://neo4j:7687（docker-compose.yml 中已自动设置）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# ===== JWT 认证配置 =====
# 生产环境务必换成随机长字符串（至少 32 位）
JWT_SECRET_KEY=papermind-change-this-secret-in-production
JWT_EXPIRE_HOURS=168

# ===== SQLite 数据库路径（Docker 部署时使用） =====
# 不设置则默认为项目根目录下的 sessions.db
# Docker 部署时 docker-compose.yml 自动设置为 /app/data/sessions.db
# DB_PATH=/app/data/sessions.db
